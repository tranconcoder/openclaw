{
  "version": 1,
  "jobs": [
    {
      "id": "daily-it-news",
      "name": "Daily IT News Summary",
      "description": "Gửi bản tin IT & Web Dev hàng ngày vào 7h sáng và 8h tối",
      "enabled": false,
      "schedule": {
        "kind": "cron",
        "cron": "0 7,20 * * *",
        "stagger": "1m"
      },
      "sessionTarget": "isolated",
      "payload": {
        "kind": "agentTurn",
        "message": "lấy tin tức IT hôm nay và tóm tắt chi tiết cho tôi"
      },
      "delivery": {
        "channel": "telegram",
        "to": "7645177112",
        "announce": true,
        "mode": "announce"
      },
      "state": {
        "scheduleErrorCount": 3,
        "lastError": "schedule error: Error: invalid cron schedule: expr is required"
      }
    }
  ]
}